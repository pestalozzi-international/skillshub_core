 "client_script": "frappe.web_form.after_load = function() {\n\n    // Properly hide the Data field via Frappe API\n    frappe.web_form.set_df_property('skills_html', 'hidden', 1);\n\n    frappe.call({\n        method: 'frappe.client.get_list',\n        args: {\n            doctype: 'SkillsHub Soft Skills',\n            fields: ['name'],\n            limit: 100,\n            order_by: 'name asc'\n        },\n        callback: function(r) {\n            if (!r.message) return;\n\n            let html = `\n              <div style=\"margin:16px 0 8px; font-weight:600; font-size:14px;\">\n                Which soft skills have you learned so far?\n              </div>\n              <div style=\"margin-bottom:10px; font-size:12px; color:#8d99a6;\">\n                Select all that apply\n              </div>\n              <div id=\"skills-checkbox-wrap\"\n                   style=\"display:flex; flex-wrap:wrap; gap:10px; padding:4px 0; margin-bottom:16px;\">`;\n\n            r.message.forEach(function(s) {\n                html += `\n                  <label style=\"display:flex; align-items:center; gap:6px;\n                                background:#f0f4ff; padding:8px 14px;\n                                border-radius:20px; cursor:pointer;\n                                font-size:13px; border:1px solid #d0d8ff;\n                                user-select:none;\">\n                    <input type=\"checkbox\" class=\"skill-pick\"\n                           value=\"${s.name}\"\n                           style=\"width:14px; height:14px; cursor:pointer;\">\n                    ${s.name}\n                  </label>`;\n            });\n\n            html += `</div>`;\n\n            // Insert before the hidden skills_learned table field\n            $('[data-fieldname=\"skills_learned\"]').before(html);\n\n            // Pre-tick existing rows if editing\n            let existing = frappe.web_form.get_value('skills_learned') || [];\n            existing.forEach(function(row) {\n                $(`.skill-pick[value=\"${row.soft_skill_name}\"]`)\n                    .prop('checked', true);\n            });\n        }\n    });\n};\n\nfrappe.web_form.validate = function() {\n    let rows = [];\n    $('.skill-pick:checked').each(function() {\n        rows.push({ soft_skill_name: $(this).val() });\n    });\n    frappe.web_form.set_value('skills_learned', rows);\n    // Return true to allow save to proceed\n    return true;\n};",
